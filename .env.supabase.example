# Runtime (pooler) URL used by app traffic
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres

# Optional: direct DB URL for migrations (recommended)
DATABASE_URL_MIGRATIONS=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres

DB_SSL=require
DB_PREPARE=false
DB_MAX_CONNECTIONS=10
