{
  "name": "@spell/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:bypass": "VITE_AUTH_BYPASS=true vite",
    "typecheck": "tsc --noEmit",
    "typecheck:tools": "tsc --noEmit -p tsconfig.tools.json",
    "build": "vite build",
    "preview": "vite preview",
    "test": "bun test src/",
    "test:e2e": "playwright test",
    "test:e2e:auth": "playwright test -c playwright.auth.config.ts",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:auth:ui": "playwright test -c playwright.auth.config.ts --ui"
  },
  "dependencies": {
    "@spell/engine": "workspace:*",
    "lucide-react": "^0.577.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@happy-dom/global-registrator": "^20.8.4",
    "@playwright/test": "^1.56.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.9",
    "@types/node": "^24.6.0",
    "@types/react": "^18.3.23",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.5.2",
    "happy-dom": "^20.8.4",
    "typescript": "^5.9.3",
    "vite": "^6.3.5"
  }
}
